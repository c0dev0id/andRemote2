<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndRemote2" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bottom_bar_bg</item>
        <item name="android:navigationBarColor">@color/bottom_bar_bg</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.AndRemote2.AlertDialog</item>
        <item name="fontFamily">@font/apotek</item>
        <item name="android:fontFamily">@font/apotek</item>
    </style>

    <style name="Widget.AndRemote2.Button.Orange" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="iconTint">@color/text_primary</item>
        <item name="cornerRadius">@dimen/corner_radius_default</item>
    </style>

    <style name="Widget.AndRemote2.Button.Dark" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/button_inactive</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="iconTint">@color/text_primary</item>
        <item name="cornerRadius">@dimen/corner_radius_default</item>
    </style>

    <style name="Widget.AndRemote2.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="iconTint">@color/text_primary</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="cornerRadius">@dimen/corner_radius_default</item>
    </style>

    <style name="ThemeOverlay.AndRemote2.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>
</resources>
