<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="@string/app_name"
                app:subtitle="DMD Remote 2 Emulator"/>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Toggle Overlay Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleOverlay"
                    style="@style/Widget.AndRemote2.Button.Orange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_overlay"
                    android:layout_marginBottom="8dp"/>

                <!-- Grant Permission via Shizuku -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantShizuku"
                    style="@style/Widget.AndRemote2.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/grant_via_shizuku"
                    android:layout_marginBottom="16dp"/>

                <!-- Overlay Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/overlay_settings"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/overlay_size"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderSize"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="25"
                                android:valueTo="100"
                                android:stepSize="1"
                                app:labelBehavior="gone"
                                android:value="75"/>

                            <TextView
                                android:id="@+id/tvSize"
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="75%"
                                android:textAlignment="center"
                                android:layout_marginStart="8dp"/>

                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/overlay_opacity"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.slider.Slider
                                android:id="@+id/sliderOpacity"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:valueFrom="20"
                                android:valueTo="100"
                                android:stepSize="1"
                                app:labelBehavior="gone"
                                android:value="80"/>

                            <TextView
                                android:id="@+id/tvOpacity"
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="80%"
                                android:textAlignment="center"
                                android:layout_marginStart="8dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Key Mappings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/key_mappings"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <!-- Preset Toggle -->
                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/togglePreset"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPresetDmd"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/preset_dmd_remote_2"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPresetCustom"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="@string/preset_custom"/>

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"/>

                        <!-- Key assignment table (populated dynamically) -->
                        <LinearLayout
                            android:id="@+id/remoteKeyTable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp"/>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"/>

                        <!-- Key Mapping Wizard Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMapRemote"
                            style="@style/Widget.AndRemote2.Button.Dark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_map_remote"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Full-screen wizard overlay (initially hidden) -->
    <include
        android:id="@+id/wizardPanel"
        layout="@layout/panel_key_wizard"
        android:visibility="gone"/>

</FrameLayout>
