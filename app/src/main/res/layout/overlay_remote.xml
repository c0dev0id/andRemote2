<?xml version="1.0" encoding="utf-8"?>
<de.codevoid.andremote2.views.DraggableOverlayLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/overlay_bg"
    android:padding="21dp">

    <!-- Joystick on top -->
    <de.codevoid.andremote2.views.JoystickView
        android:id="@+id/joystickView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="11dp"/>

    <!-- Bottom row: Lever | Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center_vertical">

        <!-- Lever on the left -->
        <de.codevoid.andremote2.views.LeverView
            android:id="@+id/leverView"
            android:layout_width="66dp"
            android:layout_height="173dp"
            android:layout_marginEnd="11dp"/>

        <!-- Buttons stacked on right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <de.codevoid.andremote2.views.ButtonView
                android:id="@+id/buttonTop"
                android:layout_width="93dp"
                android:layout_height="73dp"
                android:layout_marginBottom="11dp"/>

            <de.codevoid.andremote2.views.ButtonView
                android:id="@+id/buttonBottom"
                android:layout_width="93dp"
                android:layout_height="73dp"/>

        </LinearLayout>
    </LinearLayout>
</de.codevoid.andremote2.views.DraggableOverlayLayout>
